<?xml version="1.0" encoding="utf-8"?>
<!--
  Disables both Auto Backup (Google Drive) and Device-to-Device transfer
  for RateHelper. The app stores nothing valuable enough to back up, and
  exfiltrating a sideloaded driver-stats counter set off-device is not a
  user expectation. Prevents shared_prefs/*.xml leaving the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
